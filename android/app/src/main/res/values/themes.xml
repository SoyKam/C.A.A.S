<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ================== BASE THEME ================== -->
    <style name="Theme.CAAS" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/orange</item>
        <item name="colorPrimaryVariant">@color/orange_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/orange</item>
        <item name="colorSecondaryVariant">@color/orange_dark</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="android:statusBarColor">@color/status_bar</item>
    </style>

    <style name="Theme.CAAS.NoActionBar" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/orange</item>
        <item name="colorPrimaryVariant">@color/orange_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/orange</item>
        <item name="colorSecondaryVariant">@color/orange_dark</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
    </style>

    <!-- ================== TEXT INPUT ================== -->
    <style name="Widget.CAAS.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/input_bg</item>
        <item name="boxCornerRadiusTopStart">@dimen/input_corner_radius</item>
        <item name="boxCornerRadiusTopEnd">@dimen/input_corner_radius</item>
        <item name="boxCornerRadiusBottomStart">@dimen/input_corner_radius</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/input_corner_radius</item>
        <item name="boxStrokeColor">@color/input_border</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>
    </style>

    <!-- ================== BUTTONS ================== -->
    <style name="Widget.CAAS.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/orange</item>
        <item name="cornerRadius">@dimen/button_corner_radius</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.03</item>
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Widget.CAAS.Button.PrimaryLg" parent="Widget.CAAS.Button.Primary">
        <item name="android:minHeight">@dimen/button_height_lg</item>
    </style>

    <style name="Widget.CAAS.Button.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">@dimen/button_corner_radius</item>
        <item name="strokeColor">@color/orange</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="android:textColor">@color/orange</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="Widget.CAAS.Button.Ghost" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="cornerRadius">@dimen/button_corner_radius</item>
    </style>

    <!-- Legacy compat -->
    <style name="Widget.CAAS.Button.Main" parent="Widget.CAAS.Button.Primary" />
    <style name="ButtonStyle.Primary" parent="Widget.CAAS.Button.Primary" />
    <style name="ButtonStyle.PrimarySmall" parent="Widget.CAAS.Button.Primary">
        <item name="android:minHeight">@dimen/button_height_sm</item>
        <item name="android:textSize">@dimen/text_size_caption</item>
    </style>
    <style name="ButtonStyle.TextButton" parent="Widget.CAAS.Button.Ghost">
        <item name="android:textSize">@dimen/text_size_caption_xs</item>
    </style>

    <!-- ================== TEXT STYLES ================== -->
    <style name="TextStyle" />

    <style name="TextStyle.Display">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/text_size_display</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextStyle.Title">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/text_size_title</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="TextStyle.Headline">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/text_size_headline</item>
    </style>

    <style name="TextStyle.Body">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_size_body</item>
    </style>

    <style name="TextStyle.Subtitle">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">@dimen/text_size_body_sm</item>
    </style>

    <style name="TextStyle.Caption">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">@dimen/text_size_caption</item>
    </style>

    <style name="TextStyle.CaptionXs">
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:textSize">@dimen/text_size_caption_xs</item>
    </style>

    <style name="TextStyle.Overline">
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:textSize">@dimen/text_size_overline</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- ================== CARD STYLES ================== -->
    <style name="CardStyle" />

    <style name="CardStyle.Default">
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="cardBackgroundColor">@color/card_background</item>
        <item name="strokeColor">@color/border</item>
        <item name="strokeWidth">@dimen/card_stroke_width</item>
    </style>

    <style name="CardStyle.ListItem" parent="CardStyle.Default" />

    <style name="CardStyle.Container" parent="CardStyle.Default">
        <item name="cardElevation">@dimen/card_elevation_high</item>
    </style>

    <style name="CardStyle.ActionGrid">
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="cardBackgroundColor">@color/card_background</item>
        <item name="strokeColor">@color/border</item>
        <item name="strokeWidth">@dimen/card_stroke_width</item>
    </style>

    <!-- ================== ICON CONTAINER ================== -->
    <style name="IconContainer">
        <item name="android:layout_width">@dimen/icon_container_md</item>
        <item name="android:layout_height">@dimen/icon_container_md</item>
    </style>

    <style name="IconContainer.Orange">
        <item name="android:background">@drawable/icon_bg_orange</item>
    </style>

    <style name="IconContainer.Green">
        <item name="android:background">@drawable/icon_bg_green</item>
    </style>

    <style name="IconContainer.Red">
        <item name="android:background">@drawable/icon_bg_red</item>
    </style>

    <style name="IconContainer.Blue">
        <item name="android:background">@drawable/icon_bg_blue</item>
    </style>

    <!-- ================== FAB ================== -->
    <style name="Widget.CAAS.FAB" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="backgroundTint">@color/orange</item>
        <item name="tint">@color/white</item>
        <item name="shapeAppearanceOverlay">@style/FABShape</item>
        <item name="elevation">8dp</item>
    </style>

    <style name="FABShape">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/fab_radius</item>
    </style>

    <!-- ================== BOTTOM NAV ================== -->
    <style name="Widget.CAAS.BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="backgroundTint">@color/nav_bg</item>
        <item name="itemIconTint">@color/bottom_nav_colors</item>
        <item name="itemTextColor">@color/bottom_nav_colors</item>
        <item name="itemTextAppearanceActive">@style/TextStyle.CaptionXs</item>
        <item name="itemTextAppearanceInactive">@style/TextStyle.CaptionXs</item>
        <item name="labelVisibilityMode">labeled</item>
    </style>

</resources>