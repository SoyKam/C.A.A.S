<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme con ActionBar (para otras Activities) -->
    <style name="Theme.CAAS" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Surface and background colors. -->
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/background</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>

    <!-- Tema sin ActionBar para AuthActivity y HomeActivity -->
    <style name="Theme.CAAS.NoActionBar" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Surface and background colors. -->
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/background</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">#FFFFFF</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
    </style>

    <style name="Widget.CAAS.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">#FFFFFF</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">#E5E7EB</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">1dp</item>
        <item name="hintTextColor">#6B7280</item>
        <item name="android:textColorHint">#9CA3AF</item>
    </style>

    <style name="Widget.CAAS.Button.Main" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/button_orange</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- ================== TEXT STYLES ================== -->
    <style name="TextStyle" />

    <style name="TextStyle.Title">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/text_size_body_lg</item>
    </style>

    <style name="TextStyle.Subtitle">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">@dimen/text_size_body_sm</item>
    </style>

    <style name="TextStyle.Caption">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">@dimen/text_size_caption</item>
    </style>

    <style name="TextStyle.CaptionXs">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">@dimen/text_size_caption_xs</item>
    </style>

    <!-- ================== CARD STYLES ================== -->
    <style name="CardStyle" />

    <style name="CardStyle.ListItem">
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="cardBackgroundColor">@color/card_background</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">@dimen/card_stroke_width</item>
    </style>

    <style name="CardStyle.Container">
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardElevation">@dimen/card_elevation_high</item>
        <item name="cardBackgroundColor">@color/card_background</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">@dimen/card_stroke_width</item>
    </style>

    <!-- ================== BUTTON STYLES ================== -->
    <style name="ButtonStyle" />

    <style name="ButtonStyle.Primary">
        <item name="cornerRadius">@dimen/button_corner_radius</item>
        <item name="backgroundTint">@color/button_orange</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="ButtonStyle.PrimarySmall">
        <item name="cornerRadius">@dimen/button_corner_radius</item>
        <item name="backgroundTint">@color/button_orange</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">@dimen/text_size_caption</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="ButtonStyle.TextButton">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">@dimen/text_size_caption_xs</item>
    </style>

</resources>