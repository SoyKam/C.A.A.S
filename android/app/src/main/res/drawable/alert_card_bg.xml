<?xml version="1.0" encoding="utf-8"?>
<!-- Alert card left border accent -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/red"/>
            <corners android:topLeftRadius="@dimen/card_corner_radius"
                     android:bottomLeftRadius="@dimen/card_corner_radius"/>
        </shape>
    </item>
    <item android:left="3dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/card_background"/>
            <corners android:topRightRadius="@dimen/card_corner_radius"
                     android:bottomRightRadius="@dimen/card_corner_radius"/>
        </shape>
    </item>
</layer-list>
