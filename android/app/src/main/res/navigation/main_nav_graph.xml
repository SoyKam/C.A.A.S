<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_nav_graph"
    app:startDestination="@id/homeFragment">

    <!-- ===== TOP-LEVEL TAB DESTINATIONS ===== -->

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.caas.app.ui.home.HomeFragment"
        android:label="Inicio">
        <action
            android:id="@+id/action_home_to_businessDetail"
            app:destination="@id/businessDetailFragment"/>
        <action
            android:id="@+id/action_home_to_createBusiness"
            app:destination="@id/createBusinessFragment"/>
        <action
            android:id="@+id/action_home_to_lowStockSummary"
            app:destination="@id/lowStockSummaryFragment">
            <argument
                android:name="businessId"
                app:argType="string"/>
        </action>
        <action
            android:id="@+id/action_home_to_businessList"
            app:destination="@id/businessListFragment"/>
    </fragment>

    <fragment
        android:id="@+id/chartsFragment"
        android:name="com.caas.app.ui.reports.ChartsFragment"
        android:label="Estadísticas"/>

    <fragment
        android:id="@+id/businessListFragment"
        android:name="com.caas.app.ui.business.BusinessListFragment"
        android:label="Mis Negocios">
        <action
            android:id="@+id/action_businessList_to_businessDetail"
            app:destination="@id/businessDetailFragment"/>
        <action
            android:id="@+id/action_businessList_to_createBusiness"
            app:destination="@id/createBusinessFragment"/>
    </fragment>

    <fragment
        android:id="@+id/reportsFragment"
        android:name="com.caas.app.ui.reports.ReportsFragment"
        android:label="Movimientos"/>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.caas.app.ui.profile.ProfileFragment"
        android:label="Perfil"/>

    <!-- ===== BUSINESS MANAGEMENT ===== -->

    <fragment
        android:id="@+id/businessDetailFragment"
        android:name="com.caas.app.ui.business.BusinessDetailFragment"
        android:label="Detalle del Negocio">
        <argument
            android:name="businessId"
            app:argType="string"/>
        <action
            android:id="@+id/action_businessDetail_to_editBusiness"
            app:destination="@id/editBusinessFragment">
            <argument
                android:name="businessId"
                app:argType="string"/>
        </action>
        <action
            android:id="@+id/action_businessDetail_to_businessList"
            app:destination="@id/businessListFragment"
            app:popUpTo="@id/businessListFragment"
            app:popUpToInclusive="true"/>
        <action
            android:id="@+id/action_businessDetail_to_branchList"
            app:destination="@id/branchListFragment">
            <argument
                android:name="businessId"
                app:argType="string"/>
        </action>
        <action
            android:id="@+id/action_businessDetail_to_productList"
            app:destination="@id/productListFragment">
            <argument
                android:name="businessId"
                app:argType="string"/>
        </action>
        <action
            android:id="@+id/action_businessDetail_to_providerList"
            app:destination="@id/providerListFragment">
            <argument
                android:name="businessId"
                app:argType="string"/>
        </action>
        <action
            android:id="@+id/action_businessDetail_to_inventorySummary"
            app:destination="@id/inventorySummaryFragment">
            <argument
                android:name="businessId"
                app:argType="string"/>
        </action>
        <action
            android:id="@+id/action_businessDetail_to_lowStockSummary"
            app:destination="@id/lowStockSummaryFragment">
            <argument
                android:name="businessId"
                app:argType="string"/>
        </action>
    </fragment>

    <fragment
        android:id="@+id/createBusinessFragment"
        android:name="com.caas.app.ui.business.CreateBusinessFragment"
        android:label="Crear Negocio">
        <action
            android:id="@+id/action_createBusiness_to_businessList"
            app:destination="@id/businessListFragment"
            app:popUpTo="@id/businessListFragment"
            app:popUpToInclusive="true"/>
    </fragment>

    <fragment
        android:id="@+id/editBusinessFragment"
        android:name="com.caas.app.ui.business.EditBusinessFragment"
        android:label="Editar Negocio">
        <argument
            android:name="businessId"
            app:argType="string"/>
        <action
            android:id="@+id/action_editBusiness_to_businessDetail"
            app:destination="@id/businessDetailFragment"
            app:popUpTo="@id/businessDetailFragment"
            app:popUpToInclusive="false"/>
    </fragment>

    <!-- ===== BRANCH MANAGEMENT ===== -->

    <fragment
        android:id="@+id/branchListFragment"
        android:name="com.caas.app.ui.business.BranchListFragment"
        android:label="Sucursales">
        <argument
            android:name="businessId"
            app:argType="string"/>
        <action
            android:id="@+id/action_branchList_to_createBranch"
            app:destination="@id/createBranchFragment">
            <argument
                android:name="businessId"
                app:argType="string"/>
        </action>
        <action
            android:id="@+id/action_branchList_to_editBranch"
            app:destination="@id/editBranchFragment">
            <argument
                android:name="businessId"
                app:argType="string"/>
            <argument
                android:name="branchId"
                app:argType="string"/>
        </action>
        <action
            android:id="@+id/action_branchList_to_branchDetail"
            app:destination="@id/branchDetailFragment">
            <argument
                android:name="businessId"
                app:argType="string"/>
            <argument
                android:name="branchId"
                app:argType="string"/>
        </action>
    </fragment>

    <fragment
        android:id="@+id/branchDetailFragment"
        android:name="com.caas.app.ui.business.BranchDetailFragment"
        android:label="Detalle de Sucursal">
        <argument
            android:name="businessId"
            app:argType="string"/>
        <argument
            android:name="branchId"
            app:argType="string"/>
        <action
            android:id="@+id/action_branchDetail_to_editBranch"
            app:destination="@id/editBranchFragment">
            <argument
                android:name="businessId"
                app:argType="string"/>
            <argument
                android:name="branchId"
                app:argType="string"/>
        </action>
        <action
            android:id="@+id/action_branchDetail_to_stockList"
            app:destination="@id/stockListFragment">
            <argument
                android:name="businessId"
                app:argType="string"/>
            <argument
                android:name="branchId"
                app:argType="string"/>
        </action>
    </fragment>

    <fragment
        android:id="@+id/createBranchFragment"
        android:name="com.caas.app.ui.business.CreateBranchFragment"
        android:label="Crear Sucursal">
        <argument
            android:name="businessId"
            app:argType="string"/>
    </fragment>

    <fragment
        android:id="@+id/editBranchFragment"
        android:name="com.caas.app.ui.business.EditBranchFragment"
        android:label="Editar Sucursal">
        <argument
            android:name="businessId"
            app:argType="string"/>
        <argument
            android:name="branchId"
            app:argType="string"/>
    </fragment>

    <!-- ===== PRODUCT MANAGEMENT ===== -->

    <fragment
        android:id="@+id/productListFragment"
        android:name="com.caas.app.ui.product.ProductListFragment"
        android:label="Productos">
        <argument
            android:name="businessId"
            app:argType="string"/>
        <action
            android:id="@+id/action_productList_to_createProduct"
            app:destination="@id/createProductFragment">
            <argument
                android:name="businessId"
                app:argType="string"/>
        </action>
        <action
            android:id="@+id/action_productList_to_productDetail"
            app:destination="@id/productDetailFragment">
            <argument
                android:name="businessId"
                app:argType="string"/>
            <argument
                android:name="productId"
                app:argType="string"/>
        </action>
    </fragment>

    <fragment
        android:id="@+id/createProductFragment"
        android:name="com.caas.app.ui.product.CreateProductFragment"
        android:label="Nuevo Producto">
        <argument
            android:name="businessId"
            app:argType="string"/>
    </fragment>

    <fragment
        android:id="@+id/productDetailFragment"
        android:name="com.caas.app.ui.product.ProductDetailFragment"
        android:label="Detalle del Producto">
        <argument
            android:name="businessId"
            app:argType="string"/>
        <argument
            android:name="productId"
            app:argType="string"/>
        <action
            android:id="@+id/action_productDetail_to_editProduct"
            app:destination="@id/editProductFragment">
            <argument
                android:name="businessId"
                app:argType="string"/>
            <argument
                android:name="productId"
                app:argType="string"/>
        </action>
    </fragment>

    <fragment
        android:id="@+id/editProductFragment"
        android:name="com.caas.app.ui.product.EditProductFragment"
        android:label="Editar Producto">
        <argument
            android:name="businessId"
            app:argType="string"/>
        <argument
            android:name="productId"
            app:argType="string"/>
        <action
            android:id="@+id/action_editProduct_to_productList"
            app:destination="@id/productListFragment"
            app:popUpTo="@id/productListFragment"
            app:popUpToInclusive="true">
            <argument
                android:name="businessId"
                app:argType="string"/>
        </action>
    </fragment>

    <!-- ===== INVENTORY SUMMARY ===== -->

    <fragment
        android:id="@+id/inventorySummaryFragment"
        android:name="com.caas.app.ui.inventory.InventorySummaryFragment"
        android:label="Resumen de Inventario">
        <argument
            android:name="businessId"
            app:argType="string"/>
        <action
            android:id="@+id/action_inventorySummary_to_registerEntry"
            app:destination="@id/registerEntryFragment">
            <argument android:name="businessId" app:argType="string"/>
            <argument android:name="branchId" app:argType="string"/>
        </action>
        <action
            android:id="@+id/action_inventorySummary_to_registerExit"
            app:destination="@id/registerExitFragment">
            <argument android:name="businessId" app:argType="string"/>
            <argument android:name="branchId" app:argType="string"/>
        </action>
        <action
            android:id="@+id/action_inventorySummary_to_stockAlerts"
            app:destination="@id/stockAlertsFragment">
            <argument android:name="businessId" app:argType="string"/>
            <argument android:name="branchId" app:argType="string" android:defaultValue=""/>
        </action>
    </fragment>

    <!-- ===== LOW STOCK SUMMARY ===== -->

    <fragment
        android:id="@+id/lowStockSummaryFragment"
        android:name="com.caas.app.ui.stock.LowStockSummaryFragment"
        android:label="Stock Crítico">
        <argument
            android:name="businessId"
            app:argType="string"/>
        <action
            android:id="@+id/action_lowStockSummary_to_stockAlerts"
            app:destination="@id/stockAlertsFragment">
            <argument
                android:name="businessId"
                app:argType="string"/>
        </action>
    </fragment>

    <!-- ===== STOCK MANAGEMENT ===== -->

    <fragment
        android:id="@+id/stockListFragment"
        android:name="com.caas.app.ui.stock.StockListFragment"
        android:label="Inventario">
        <argument
            android:name="businessId"
            app:argType="string"/>
        <argument
            android:name="branchId"
            app:argType="string"/>
        <action
            android:id="@+id/action_stockList_to_registerEntry"
            app:destination="@id/registerEntryFragment">
            <argument
                android:name="businessId"
                app:argType="string"/>
            <argument
                android:name="branchId"
                app:argType="string"/>
        </action>
        <action
            android:id="@+id/action_stockList_to_registerExit"
            app:destination="@id/registerExitFragment">
            <argument
                android:name="businessId"
                app:argType="string"/>
            <argument
                android:name="branchId"
                app:argType="string"/>
        </action>
        <action
            android:id="@+id/action_stockList_to_stockAlerts"
            app:destination="@id/stockAlertsFragment">
            <argument
                android:name="businessId"
                app:argType="string"/>
            <argument
                android:name="branchId"
                app:argType="string"/>
        </action>
        <action
            android:id="@+id/action_stockList_to_stockMovements"
            app:destination="@id/stockMovementsFragment">
            <argument
                android:name="businessId"
                app:argType="string" />
            <argument
                android:name="branchId"
                app:argType="string" />
        </action>
    </fragment>

    <fragment
        android:id="@+id/registerEntryFragment"
        android:name="com.caas.app.ui.stock.RegisterEntryFragment"
        android:label="Registrar Entrada">
        <argument
            android:name="businessId"
            app:argType="string"/>
        <argument
            android:name="branchId"
            app:argType="string"/>
    </fragment>

    <fragment
        android:id="@+id/registerExitFragment"
        android:name="com.caas.app.ui.stock.RegisterExitFragment"
        android:label="Registrar Salida">
        <argument
            android:name="businessId"
            app:argType="string"/>
        <argument
            android:name="branchId"
            app:argType="string"/>
    </fragment>

    <fragment
        android:id="@+id/stockAlertsFragment"
        android:name="com.caas.app.ui.stock.StockAlertsFragment"
        android:label="Alertas de Stock">
        <argument
            android:name="businessId"
            app:argType="string"/>
        <argument
            android:name="branchId"
            app:argType="string"
            android:defaultValue=""/>
    </fragment>

    <fragment
        android:id="@+id/stockMovementsFragment"
        android:name="com.caas.app.ui.stock.StockMovementsFragment"
        android:label="Movimientos">
        <argument
            android:name="businessId"
            app:argType="string" />
        <argument
            android:name="branchId"
            app:argType="string" />
        <action
            android:id="@+id/action_stockMovements_to_movementDetail"
            app:destination="@id/movementDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/movementDetailFragment"
        android:name="com.caas.app.ui.stock.MovementDetailFragment"
        android:label="Detalle del Movimiento">
        <argument
            android:name="businessId"
            app:argType="string" />
        <argument
            android:name="branchId"
            app:argType="string" />
        <argument
            android:name="movementId"
            app:argType="string" />
    </fragment>

    <!-- ===== PROVIDER MANAGEMENT ===== -->

    <fragment
        android:id="@+id/providerListFragment"
        android:name="com.caas.app.ui.provider.ProviderListFragment"
        android:label="Proveedores">
        <argument
            android:name="businessId"
            app:argType="string"/>
        <action
            android:id="@+id/action_providerList_to_createProvider"
            app:destination="@id/createProviderFragment">
            <argument
                android:name="businessId"
                app:argType="string"/>
        </action>
        <action
            android:id="@+id/action_providerList_to_providerDetail"
            app:destination="@id/providerDetailFragment">
            <argument
                android:name="businessId"
                app:argType="string"/>
            <argument
                android:name="providerId"
                app:argType="string"/>
        </action>
    </fragment>

    <fragment
        android:id="@+id/createProviderFragment"
        android:name="com.caas.app.ui.provider.CreateProviderFragment"
        android:label="Nuevo Proveedor">
        <argument
            android:name="businessId"
            app:argType="string"/>
    </fragment>

    <fragment
        android:id="@+id/providerDetailFragment"
        android:name="com.caas.app.ui.provider.ProviderDetailFragment"
        android:label="Detalle del Proveedor">
        <argument
            android:name="businessId"
            app:argType="string"/>
        <argument
            android:name="providerId"
            app:argType="string"/>
        <action
            android:id="@+id/action_providerDetail_to_editProvider"
            app:destination="@id/editProviderFragment">
            <argument
                android:name="businessId"
                app:argType="string"/>
            <argument
                android:name="providerId"
                app:argType="string"/>
        </action>
        <action
            android:id="@+id/action_providerDetail_to_associateProduct"
            app:destination="@id/associateProductFragment">
            <argument
                android:name="businessId"
                app:argType="string"/>
            <argument
                android:name="providerId"
                app:argType="string"/>
        </action>
    </fragment>

    <fragment
        android:id="@+id/editProviderFragment"
        android:name="com.caas.app.ui.provider.EditProviderFragment"
        android:label="Editar Proveedor">
        <argument
            android:name="businessId"
            app:argType="string"/>
        <argument
            android:name="providerId"
            app:argType="string"/>
        <action
            android:id="@+id/action_editProvider_to_providerList"
            app:destination="@id/providerListFragment"
            app:popUpTo="@id/providerListFragment"
            app:popUpToInclusive="true">
            <argument
                android:name="businessId"
                app:argType="string"/>
        </action>
    </fragment>

    <fragment
        android:id="@+id/associateProductFragment"
        android:name="com.caas.app.ui.provider.AssociateProductFragment"
        android:label="Asociar Producto">
        <argument
            android:name="businessId"
            app:argType="string"/>
        <argument
            android:name="providerId"
            app:argType="string"/>
    </fragment>

</navigation>
