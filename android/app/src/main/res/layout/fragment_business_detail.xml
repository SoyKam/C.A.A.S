<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ===== HEADER ===== -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/header_gradient"
            android:paddingHorizontal="@dimen/header_padding_horizontal"
            android:paddingVertical="16dp"
            android:minHeight="@dimen/header_height">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_back"
                app:tint="@color/white"
                android:padding="4dp"
                android:contentDescription="Volver"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_toEndOf="@id/btnBack"
                android:layout_marginStart="8dp"
                android:text=""
                android:textColor="@color/header_text"
                android:textSize="@dimen/text_size_title"
                android:textStyle="bold"/>

            <ImageView
                android:id="@+id/btnEdit"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_edit"
                app:tint="@color/white"
                android:padding="4dp"
                android:contentDescription="Editar"/>
        </RelativeLayout>

        <!-- ===== INFO CARD ===== -->
        <com.google.android.material.card.MaterialCardView
            style="@style/CardStyle.Default"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/spacing_lg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <!-- Avatar + Name -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/spacing_sm">

                    <!-- Initials avatar -->
                    <FrameLayout
                        android:layout_width="@dimen/icon_container_lg"
                        android:layout_height="@dimen/icon_container_lg"
                        android:background="@drawable/circle_orange_bg"
                        android:layout_marginEnd="@dimen/spacing_sm">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="DL"
                            android:textColor="@color/white"
                            android:textSize="@dimen/text_size_title"
                            android:textStyle="bold"/>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvBusinessName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_size_body_lg"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvSector"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_caption"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- NIT + Estado row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="@dimen/spacing_sm"
                        android:background="@drawable/stat_box_bg"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NIT"
                            android:textColor="@color/text_tertiary"
                            android:textSize="@dimen/text_size_caption_xs"/>

                        <TextView
                            android:id="@+id/tvTaxId"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_size_body_sm"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/stat_box_bg"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Estado"
                            android:textColor="@color/text_tertiary"
                            android:textSize="@dimen/text_size_caption_xs"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Activo"
                            android:textColor="@color/green"
                            android:textSize="@dimen/text_size_body_sm"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== SECTION: Administrar ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Administrar"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_size_body"
            android:textStyle="bold"
            android:layout_marginStart="@dimen/spacing_lg"
            android:layout_marginBottom="@dimen/spacing_md"/>

        <!-- ===== ACTION GRID (3 columns) ===== -->
        <androidx.gridlayout.widget.GridLayout
            xmlns:grid="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/spacing_lg"
            grid:columnCount="3"
            grid:useDefaultMargins="false">

            <!-- Sucursales -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnViewBranches"
                style="@style/CardStyle.ActionGrid"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                grid:layout_columnWeight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <FrameLayout
                        android:layout_width="@dimen/icon_container_sm"
                        android:layout_height="@dimen/icon_container_sm"
                        android:background="@drawable/icon_bg_orange"
                        android:padding="10dp"
                        android:layout_marginBottom="@dimen/spacing_sm">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_branch"
                            app:tint="@color/orange"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sucursales"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_caption"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3"
                        android:textColor="@color/text_tertiary"
                        android:textSize="@dimen/text_size_caption_xs"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Productos -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnViewProducts"
                style="@style/CardStyle.ActionGrid"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                grid:layout_columnWeight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <FrameLayout
                        android:layout_width="@dimen/icon_container_sm"
                        android:layout_height="@dimen/icon_container_sm"
                        android:background="@drawable/icon_bg_orange"
                        android:padding="10dp"
                        android:layout_marginBottom="@dimen/spacing_sm">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_product"
                            app:tint="@color/orange"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Productos"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_caption"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="48"
                        android:textColor="@color/text_tertiary"
                        android:textSize="@dimen/text_size_caption_xs"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Proveedores -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnViewProviders"
                style="@style/CardStyle.ActionGrid"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                grid:layout_columnWeight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <FrameLayout
                        android:layout_width="@dimen/icon_container_sm"
                        android:layout_height="@dimen/icon_container_sm"
                        android:background="@drawable/icon_bg_orange"
                        android:padding="10dp"
                        android:layout_marginBottom="@dimen/spacing_sm">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_provider"
                            app:tint="@color/orange"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Proveedores"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_caption"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvProviderCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/text_tertiary"
                        android:textSize="@dimen/text_size_caption_xs"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Inventario -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnInventorySummary"
                style="@style/CardStyle.ActionGrid"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                grid:layout_columnWeight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <FrameLayout
                        android:layout_width="@dimen/icon_container_sm"
                        android:layout_height="@dimen/icon_container_sm"
                        android:background="@drawable/icon_bg_orange"
                        android:padding="10dp"
                        android:layout_marginBottom="@dimen/spacing_sm">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_inventory"
                            app:tint="@color/orange"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Inventario"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_caption"
                        android:textStyle="bold"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Stock -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnViewStock"
                style="@style/CardStyle.ActionGrid"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                grid:layout_columnWeight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <FrameLayout
                        android:layout_width="@dimen/icon_container_sm"
                        android:layout_height="@dimen/icon_container_sm"
                        android:background="@drawable/icon_bg_orange"
                        android:padding="10dp"
                        android:layout_marginBottom="@dimen/spacing_sm">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_stock"
                            app:tint="@color/orange"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Stock"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_caption"
                        android:textStyle="bold"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Alertas (red accent) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnCriticalStock"
                style="@style/CardStyle.ActionGrid"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                grid:layout_columnWeight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <FrameLayout
                        android:layout_width="@dimen/icon_container_sm"
                        android:layout_height="@dimen/icon_container_sm"
                        android:background="@drawable/icon_bg_red"
                        android:padding="10dp"
                        android:layout_marginBottom="@dimen/spacing_sm">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_alert"
                            app:tint="@color/red"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Alertas"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_caption"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvAlertCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/red"
                        android:textSize="@dimen/text_size_caption_xs"
                        android:textStyle="bold"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </androidx.gridlayout.widget.GridLayout>

        <!-- ===== QUICK STATS ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="@dimen/spacing_lg"
            android:layout_marginTop="@dimen/spacing_sm">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:background="@drawable/stat_box_bg"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/tvTotalStock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/blue"
                    android:textSize="@dimen/stat_value_size"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Stock"
                    android:textColor="@color/text_tertiary"
                    android:textSize="@dimen/text_size_caption_xs"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/stat_box_bg"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="48"
                    android:textColor="@color/orange"
                    android:textSize="@dimen/stat_value_size"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Productos"
                    android:textColor="@color/text_tertiary"
                    android:textSize="@dimen/text_size_caption_xs"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_sm"
                android:background="@drawable/stat_box_bg"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/tvBranchesCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/green"
                    android:textSize="@dimen/stat_value_size"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sucursales"
                    android:textColor="@color/text_tertiary"
                    android:textSize="@dimen/text_size_caption_xs"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Loading -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_gravity="center"
            android:indeterminateTint="@color/orange"/>

    </LinearLayout>
</ScrollView>
