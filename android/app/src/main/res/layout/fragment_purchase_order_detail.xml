<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="@color/button_orange"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_back"
                android:padding="4dp"
                android:contentDescription="Volver"
                app:tint="@color/white"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Detalle de Orden"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/white"/>
        </LinearLayout>

        <!-- CARD INFO PROVEEDOR + ESTADO -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="-16dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation_high"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <!-- LOADING -->
                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone"/>

                <!-- Proveedor -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Proveedor"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_caption"/>

                        <TextView
                            android:id="@+id/tvProviderName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_size_body_lg"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="@dimen/text_size_caption"
                        app:chipMinHeight="28dp"
                        app:chipCornerRadius="14dp"/>
                </LinearLayout>

                <!-- Fecha y auto-generado -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/text_tertiary"
                        android:textSize="@dimen/text_size_caption"/>

                    <TextView
                        android:id="@+id/tvAutoGenerated"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Auto-generada"
                        android:textColor="@color/yellow"
                        android:textSize="@dimen/text_size_caption"
                        android:visibility="gone"/>
                </LinearLayout>

                <!-- Notas -->
                <TextView
                    android:id="@+id/tvNotes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_size_body"
                    android:visibility="gone"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- CARD PRODUCTOS -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <!-- Cabecera tabla -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Producto"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_size_caption"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="64dp"
                        android:layout_height="wrap_content"
                        android:text="Cant."
                        android:gravity="center"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_size_caption"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="72dp"
                        android:layout_height="wrap_content"
                        android:text="P.Unit"
                        android:gravity="end"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_size_caption"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="Subtotal"
                        android:gravity="end"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_size_caption"
                        android:textStyle="bold"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginBottom="4dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvItems"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ACCIONES DE ESTADO -->
        <LinearLayout
            android:id="@+id/layoutActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="32dp">

            <!-- PENDING: Marcar Enviada + Cancelar -->
            <Button
                android:id="@+id/btnMarkSent"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height_lg"
                android:layout_marginBottom="10dp"
                android:text="Marcar como Enviada"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/blue"
                android:visibility="gone"
                app:cornerRadius="@dimen/button_corner_radius"/>

            <!-- SENT: Marcar Recibida -->
            <Button
                android:id="@+id/btnMarkReceived"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height_lg"
                android:layout_marginBottom="10dp"
                android:text="Confirmar Recepción"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/green"
                android:visibility="gone"
                app:cornerRadius="@dimen/button_corner_radius"/>

            <!-- CANCELAR (PENDING o SENT) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:text="Cancelar Orden"
                android:textColor="@color/red"
                android:visibility="gone"
                app:strokeColor="@color/red"
                app:strokeWidth="1dp"
                app:cornerRadius="@dimen/button_corner_radius"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
