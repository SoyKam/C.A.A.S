<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/CardStyle.Default"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_sm">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/card_padding_sm">

        <!-- IZQUIERDA -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="@dimen/spacing_md">

            <TextView
                android:id="@+id/tvProductName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_body_lg"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="1"
                android:layout_marginBottom="@dimen/spacing_xs"/>

            <TextView
                android:id="@+id/tvSku"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_caption"
                android:layout_marginBottom="@dimen/spacing_sm"/>

            <TextView
                android:id="@+id/tvMinStock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mínimo: 0"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_caption_xs"
                android:background="@drawable/stat_box_bg"
                android:paddingHorizontal="@dimen/spacing_sm"
                android:paddingVertical="@dimen/spacing_xs"/>

        </LinearLayout>

        <!-- DERECHA -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/tvQuantity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="@dimen/stat_value_size"
                android:textStyle="bold"
                android:textColor="@color/orange"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="uds"
                android:textColor="@color/text_tertiary"
                android:textSize="@dimen/text_size_caption_xxs"
                android:layout_marginBottom="@dimen/spacing_sm"/>

            <TextView
                android:id="@+id/tvStockStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/white"
                android:textSize="@dimen/text_size_caption_xxs"
                android:textStyle="bold"
                android:paddingHorizontal="@dimen/spacing_sm"
                android:paddingVertical="@dimen/spacing_xs"
                android:background="@drawable/status_badge_bg"
                android:backgroundTint="@color/orange"/>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
