<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FAFAFA"
    android:fitsSystemWindows="true">

    <!-- HEADER -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:background="@color/button_orange"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Alertas de Stock"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/white"/>

        <!-- Badge contador de no leídas -->
        <TextView
            android:id="@+id/tvAlertBadge"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@color/error_red"
            android:gravity="center"
            android:text="0"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone"/>

    </LinearLayout>

    <!-- CONTENIDO -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- TARJETA -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="10dp"
            app:cardBackgroundColor="@color/card_background"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- BOTÓN MARCAR TODAS -->
                <Button
                    android:id="@+id/btnMarkAllRead"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="MARCAR TODAS COMO LEÍDAS"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/button_orange"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone"
                    app:cornerRadius="10dp"/>

                <!-- LOADING -->

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:layout_gravity="center"
                    android:layout_marginBottom="16dp"/>

                <!-- EMPTY STATE -->

                <TextView
                    android:id="@+id/tvEmptyState"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:text="No hay alertas activas"
                    android:textSize="15sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:visibility="gone"
                    android:padding="40dp"/>

                <!-- LISTA -->

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvAlertList"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:clipToPadding="false"
                    android:paddingBottom="12dp"
                    android:visibility="gone"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</LinearLayout>
