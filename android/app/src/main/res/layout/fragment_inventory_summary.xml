<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_inventory_summary.xml -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <!-- HEADER -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/header_height"
        android:background="@drawable/header_gradient"
        android:paddingHorizontal="@dimen/header_padding_horizontal">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_back"
            app:tint="@color/white"
            android:padding="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_toEndOf="@id/btnBack"
            android:layout_marginStart="8dp"
            android:text="Inventario"
            android:textColor="@color/header_text"
            android:textSize="@dimen/text_size_title"
            android:textStyle="bold"/>
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg">

        <!-- Summary cards row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/spacing_lg">

            <com.google.android.material.card.MaterialCardView
                style="@style/CardStyle.Default"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/spacing_sm">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="@dimen/card_padding_sm">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Valor total"
                        android:textColor="@color/text_tertiary"
                        android:textSize="@dimen/text_size_caption_xs"/>

                    <TextView
                        android:id="@+id/tvTotalValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$0"
                        android:textColor="@color/orange"
                        android:textSize="@dimen/text_size_title"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/CardStyle.Default"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="@dimen/card_padding_sm">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Productos"
                        android:textColor="@color/text_tertiary"
                        android:textSize="@dimen/text_size_caption_xs"/>

                    <TextView
                        android:id="@+id/tvProductCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_title"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Branch selector -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/input_height"
            android:background="@drawable/stat_box_bg"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp"
            android:layout_marginBottom="@dimen/spacing_sm">

            <Spinner
                android:id="@+id/spinnerBranch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"/>

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_chevron_right"
                app:tint="@color/text_tertiary"
                android:rotation="90"/>
        </LinearLayout>

        <!-- LOADING -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_gravity="center"
            android:indeterminateTint="@color/orange"/>

        <!-- EMPTY STATE -->
        <TextView
            android:id="@+id/tvEmptyState"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="No hay productos en esta sucursal"
            android:textSize="15sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:visibility="gone"/>

        <!-- INVENTORY LIST -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvInventory"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="@dimen/spacing_sm"
            android:visibility="gone"/>

        <!-- ENTRY BUTTON -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRegisterEntry"
            style="@style/Widget.CAAS.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/spacing_sm"
            android:text="↑  Registrar Entrada"
            app:icon="@drawable/ic_arrow_up"
            app:iconTint="@color/white"
            app:iconGravity="textStart"/>

        <!-- EXIT BUTTON -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRegisterExit"
            style="@style/Widget.CAAS.Button.Outline"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/spacing_sm"
            android:text="↓  Registrar Salida"
            app:icon="@drawable/ic_arrow_down"
            app:iconTint="@color/orange"
            app:iconGravity="textStart"/>

        <!-- ALERTS BUTTON -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewAlerts"
            style="@style/Widget.CAAS.Button.Ghost"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height_sm"
            android:layout_marginTop="@dimen/spacing_sm"
            android:text="Ver Alertas de Stock"
            app:icon="@drawable/ic_bell"
            app:iconTint="@color/text_secondary"
            app:iconGravity="textStart"/>
    </LinearLayout>
</LinearLayout>
