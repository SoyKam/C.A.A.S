<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp">

        <!-- BRAND -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CAAS"
            android:textColor="@color/button_orange"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="56dp"/>

        <!-- SUBTITLE -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NUEVA CUENTA"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:layout_marginBottom="6dp"/>

        <!-- TITLE -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="REGÍSTRATE"
            android:textColor="@color/text_primary"
            android:textSize="30sp"
            android:textStyle="bold"
            android:layout_marginBottom="36dp"/>

        <!-- NOMBRE -->

        <TextView
            android:text="NOMBRE COMPLETO"
            android:textColor="@color/text_primary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.CAAS.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="22dp"
            app:hintEnabled="false"
            app:boxBackgroundColor="@color/input_fill"
            app:boxStrokeColor="@color/input_stroke">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/nameEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Juan Pérez"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="15sp"
                android:paddingVertical="18dp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- EMAIL -->

        <TextView
            android:text="CORREO ELECTRÓNICO"
            android:textColor="@color/text_primary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.CAAS.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="22dp"
            app:hintEnabled="false"
            app:boxBackgroundColor="@color/input_fill"
            app:boxStrokeColor="@color/input_stroke">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/emailEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="ejemplo@caas.com"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="15sp"
                android:paddingVertical="18dp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- PASSWORD -->

        <TextView
            android:text="CONTRASEÑA"
            android:textColor="@color/text_primary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.CAAS.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="36dp"
            app:hintEnabled="false"
            app:endIconMode="password_toggle"
            app:endIconTint="@color/text_hint"
            app:boxBackgroundColor="@color/input_fill"
            app:boxStrokeColor="@color/input_stroke">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/passwordEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="••••••••••••"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="15sp"
                android:paddingVertical="18dp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- BOTÓN -->

        <Button
            android:id="@+id/registerButton"
            style="@style/Widget.CAAS.Button.Main"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:text="CREAR CUENTA"
            android:textColor="@color/white"
            android:layout_marginBottom="28dp"/>

        <!-- LINK -->

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="center">

            <TextView
                android:text="¿Ya tienes cuenta? "
                android:textColor="@color/text_secondary"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/goToLoginTextView"
                android:text="Inicia sesión"
                android:textColor="@color/text_link"
                android:textStyle="bold"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- LOADING -->

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"/>

        <!-- ESPACIO FLEX -->

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <!-- FOOTER -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="48dp"
            android:text="© 2026 CAAS"
            android:textColor="@color/text_secondary"
            android:textSize="10sp" />

    </LinearLayout>

</ScrollView>