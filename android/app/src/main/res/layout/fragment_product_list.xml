<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <!-- ===== HEADER ===== -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/header_height"
        android:background="@drawable/header_gradient"
        android:paddingHorizontal="@dimen/header_padding_horizontal">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_back"
            app:tint="@color/white"
            android:padding="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_toEndOf="@id/btnBack"
            android:layout_marginStart="8dp"
            android:text="Productos"
            android:textColor="@color/header_text"
            android:textSize="@dimen/text_size_title"
            android:textStyle="bold"/>
    </RelativeLayout>

    <!-- ===== CONTENT ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg">

        <!-- Search bar -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.CAAS.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_sm"
            app:hintEnabled="false"
            app:startIconDrawable="@drawable/ic_search"
            app:startIconTint="@color/text_tertiary"
            app:boxCornerRadiusTopStart="@dimen/input_corner_radius"
            app:boxCornerRadiusTopEnd="@dimen/input_corner_radius"
            app:boxCornerRadiusBottomStart="@dimen/input_corner_radius"
            app:boxCornerRadiusBottomEnd="@dimen/input_corner_radius">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:hint="Buscar por nombre..."
                android:inputType="text"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="@dimen/text_size_body"
                android:imeOptions="actionSearch"
                android:singleLine="true"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Category chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="@dimen/spacing_sm">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupCategories"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true"
                app:chipSpacingHorizontal="6dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAll"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Todos"
                    android:checked="true"
                    app:chipCornerRadius="@dimen/chip_radius"
                    app:chipBackgroundColor="@color/surface_alt"
                    app:chipStrokeColor="@color/border"
                    app:chipStrokeWidth="1dp"
                    app:checkedIconVisible="false"/>
            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

        <!-- Product count -->
        <TextView
            android:id="@+id/tvProductCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="6 productos"
            android:textColor="@color/text_tertiary"
            android:textSize="@dimen/text_size_caption"
            android:layout_marginBottom="@dimen/spacing_sm"/>

        <!-- LOADING -->
        <include
            android:id="@+id/progressBar"
            layout="@layout/component_loading_state"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- EMPTY STATE -->
        <include
            android:id="@+id/tvEmptyState"
            layout="@layout/component_empty_state"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- Product list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvProductList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="@dimen/rv_padding_bottom"
            android:visibility="gone"/>

        <!-- FAB -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabAddProduct"
            style="@style/Widget.CAAS.FAB"
            android:layout_width="@dimen/fab_size"
            android:layout_height="@dimen/fab_size"
            android:layout_gravity="bottom|end"
            android:layout_margin="@dimen/fab_margin"
            android:contentDescription="Crear producto"
            android:src="@android:drawable/ic_input_add"/>
    </LinearLayout>
</LinearLayout>
