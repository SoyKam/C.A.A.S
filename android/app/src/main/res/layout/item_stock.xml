<?xml version="1.0" encoding="utf-8"?>

<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/CardStyle.ListItem"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/spacing_xs"
    android:layout_marginTop="@dimen/spacing_sm"
    android:layout_marginBottom="@dimen/spacing_sm">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/spacing_xl"
        android:paddingVertical="@dimen/spacing_lg">

        <!-- IZQUIERDA: nombre + badge crítico -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="@dimen/spacing_md">

            <TextView
                android:id="@+id/tvProductName"
                style="@style/TextStyle.Title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nombre del producto"
                android:layout_marginBottom="@dimen/spacing_sm"/>

            <!-- BADGE stock crítico (oculto por defecto) -->
            <TextView
                android:id="@+id/tvLowStockAlert"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@color/error_red"
                android:paddingHorizontal="@dimen/spacing_sm"
                android:paddingVertical="@dimen/spacing_xs"
                android:text="Stock crítico"
                android:textColor="@color/white"
                android:textSize="@dimen/text_size_caption_xxs"
                android:textStyle="bold"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- DERECHA: cantidad grande + botón movimientos -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/tvStockQuantity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/button_orange"
                android:textSize="@dimen/text_size_title"
                android:textStyle="bold"/>

            <TextView
                style="@style/TextStyle.CaptionXs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="uds"
                android:layout_marginBottom="@dimen/spacing_sm"/>

            <!-- Botón movimientos: texto sutil -->
            <Button
                android:id="@+id/btnViewMovements"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:minWidth="0dp"
                android:paddingHorizontal="0dp"
                android:text="Movimientos"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_caption_xs"/>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
