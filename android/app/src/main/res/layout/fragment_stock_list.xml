<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FAFAFA"
    android:fitsSystemWindows="true">

    <!-- HEADER MÁS ELEGANTE -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:background="@color/button_orange"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stock de Sucursal"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/white"/>
    </LinearLayout>

    <!-- CONTENIDO -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- TARJETA PRINCIPAL -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="10dp"
            app:cardBackgroundColor="@color/card_background"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- LOADING -->

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:layout_gravity="center"
                    android:layout_marginBottom="16dp"/>

                <!-- EMPTY STATE -->

                <TextView
                    android:id="@+id/tvEmptyState"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:text="No hay productos registrados"
                    android:textSize="15sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:visibility="gone"
                    android:padding="40dp"/>

                <!-- LISTA -->

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvStockList"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:clipToPadding="false"
                    android:paddingBottom="12dp"
                    android:visibility="gone"/>

                <!-- BOTÓN ENTRADA -->

                <Button
                    android:id="@+id/btnRegisterEntry"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="16dp"
                    android:backgroundTint="@color/button_orange"
                    android:text="↑  Registrar Entrada"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:elevation="6dp"
                    app:cornerRadius="14dp"/>

                <!-- BOTÓN SALIDA -->

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRegisterExit"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="12dp"
                    android:text="↓  Registrar Salida"
                    android:textColor="@color/button_orange"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    app:strokeColor="@color/button_orange"
                    app:strokeWidth="1dp"
                    app:cornerRadius="14dp"/>

                <!-- BOTÓN ALERTAS -->

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnViewAlerts"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="10dp"
                    android:text="Ver Alertas de Stock"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp"
                    app:cornerRadius="14dp"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</LinearLayout>
