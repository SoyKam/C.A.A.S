<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <!-- HEADER -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/header_height"
        android:background="@drawable/header_gradient"
        android:paddingHorizontal="@dimen/header_padding_horizontal">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_back"
            app:tint="@color/white"
            android:padding="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_toEndOf="@id/btnBack"
            android:layout_marginStart="8dp"
            android:text="Stock de Sucursal"
            android:textColor="@color/header_text"
            android:textSize="@dimen/text_size_title"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/btnBack"
            android:layout_marginStart="48dp"
            android:text="Sucursal Centro"
            android:textColor="#A0FFFFFF"
            android:textSize="@dimen/text_size_body_sm"
            android:visibility="gone"/>
    </RelativeLayout>

    <!-- CONTENT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg">

        <!-- LOADING -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_gravity="center"
            android:indeterminateTint="@color/orange"/>

        <!-- EMPTY STATE -->
        <TextView
            android:id="@+id/tvEmptyState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No hay productos registrados"
            android:textSize="15sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:visibility="gone"
            android:padding="40dp"/>

        <!-- STOCK LIST -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvStockList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="@dimen/spacing_sm"
            android:visibility="gone"/>

        <!-- ENTRY BUTTON -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRegisterEntry"
            style="@style/Widget.CAAS.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/spacing_sm"
            android:text="↑  Registrar Entrada"
            app:icon="@drawable/ic_arrow_up"
            app:iconTint="@color/white"
            app:iconGravity="textStart"/>

        <!-- EXIT BUTTON -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRegisterExit"
            style="@style/Widget.CAAS.Button.Outline"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/spacing_sm"
            android:text="↓  Registrar Salida"
            app:icon="@drawable/ic_arrow_down"
            app:iconTint="@color/orange"
            app:iconGravity="textStart"/>

        <!-- ALERTS BUTTON -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewAlerts"
            style="@style/Widget.CAAS.Button.Ghost"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height_sm"
            android:layout_marginTop="@dimen/spacing_sm"
            android:text="Ver Alertas de Stock"
            app:icon="@drawable/ic_bell"
            app:iconTint="@color/text_secondary"
            app:iconGravity="textStart"/>
    </LinearLayout>
</LinearLayout>
